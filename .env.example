# ========================================
# js-doc-store-server Environment Variables
# ========================================

# Server Configuration
# --------------------
PORT=3000
NODE_ENV=development
DATA_DIR=./data

# Security Keys (Generate strong random strings)
# ---------------------------------------------
# JWT secret for token signing (min 32 characters)
JWT_SECRET=your-jwt-secret-min-32-chars-here

# Vault encryption key (min 32 characters)
VAULT_SECRET=your-vault-encryption-key-here

# Database encryption key (min 32 characters)
DB_ENCRYPTION_KEY=your-db-encryption-key-here

# Default Admin (for testing)
# ---------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin123!

# API URL (for tests)
# -------------------
# Local development:
API_URL=http://localhost:3000
# Production:
# API_URL=https://js-doc-store-server.rckflr.workers.dev

# Embedding Worker (Optional - for local dev without Cloudflare AI)
# ------------------------------------------------------------------
# Only needed if running outside Cloudflare Workers
# EMBEDDING_WORKER_URL=https://gemma-embedding-worker.YOUR_SUBDOMAIN.workers.dev
# EMBEDDING_API_KEY=your-embedding-worker-api-key

# Cloudflare (for deployment)
# -------------------------
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# CLOUDFLARE_ACCOUNT_ID=your-account-id

# KV Namespace ID (get from wrangler.toml or Cloudflare dashboard)
# KV_NAMESPACE_ID=your-kv-namespace-id

# ========================================
# Quick Start:
# 1. Copy this file: cp .env.example .env
# 2. Generate secure keys (use: openssl rand -base64 32)
# 3. Update ADMIN_EMAIL and ADMIN_PASSWORD
# 4. Run: npm install && npm start
# ========================================
