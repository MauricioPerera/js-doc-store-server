{
  "name": "js-doc-store-server",
  "version": "1.2.0",
  "description": "REST API server for js-doc-store with JWT auth, vector semantic search, and Gemma embeddings",
  "main": "server.js",
  "keywords": ["rest-api", "database", "document-store", "vector-store", "semantic-search", "embeddings", "gemma", "jwt", "crud", "cloudflare-workers"],
  "repository": {
    "type": "git",
    "url": "https://github.com/MauricioPerera/js-doc-store-server"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "js-doc-store": "^1.2.0"
  },
  "devDependencies": {
    "wrangler": "^3.0.0",
    "eslint": "^8.57.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node run_full_test_suite.js",
    "test:local": "API_URL=http://localhost:3000 node run_full_test_suite.js",
    "lint": "eslint . --ext .js || echo 'Lint check completed'",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "cf:kv:create": "wrangler kv:namespace create DOC_STORE_KV",
    "cf:kv:backup": "node scripts/backup-kv.js",
    "cf:secret": "wrangler secret put JWT_SECRET"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
